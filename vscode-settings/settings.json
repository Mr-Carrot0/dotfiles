{
    "chat.disableAIFeatures": true,
    "terminal.integrated.defaultProfile.linux": "bash",
    "editor.formatOnSave": true,
    "editor.minimap.enabled": false,
    "files.autoSave": "afterDelay",
    "html.format.contentUnformatted": "pre,code,textarea",
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "security.workspace.trust.untrustedFiles": "open",
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "update.mode": "manual",
    // "[typescript]": {
    //     "editor.defaultFormatter": "vscode.typescript-language-features"
    // },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "redhat.telemetry.enabled": false,
    "editor.tabCompletion": "on",
    "editor.useTabStops": false,
    // "godotTools.editorPath.godot4": "/home/mrcarrot/prog/Godot_v4.4.1-stable_mono_linux_x86_64/Godot_v4.4.1-stable_mono_linux.x86_64",
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "workbench.enableExperiments": false,
    "git.autofetchPeriod": 60,



    /* AI BS */
    "chat.agent.enabled": false,
    "chat.agent.maxRequests": -1,
    "chat.commandCenter.enabled": false,
    "chat.notifyWindowOnConfirmation": false,
    "chat.implicitContext.suggestedContext": false,
    "chat.checkpoints.enabled": false,
    "chat.detectParticipant.enabled": false,
    "chat.emptyChatState.enabled": false,
    "chat.extensionTools.enabled": false,
    "chat.implicitContext.enabled": {
        "panel": "never"
    },
    "chat.instructionsFilesLocations": {
        ".github/instructions": false
    },
    "chat.mcp.discovery.enabled": {
        "claude-desktop": false,
        "windsurf": false,
        "cursor-global": false,
        "cursor-workspace": false
    },
    "chat.promptFilesLocations": {
        ".github/prompts": false
    },
    "chat.sendElementsToChat.attachCSS": false,
    "chat.sendElementsToChat.attachImages": false,
    "chat.sendElementsToChat.enabled": false,
    "chat.tools.terminal.autoApprove": {    
        "rm": false,
        "rmdir": false,
        "del": false,
        "kill": false,
        "curl": false,
        "wget": false,
        "eval": false,
        "chmod": false,
        "chown": false,
        "/^Remove-Item\\b/i": false,
        "/.*/": false,
    },

    "chat.agent.codeBlockProgress": false,
    "chat.agent.thinking.generateTitles": false,
    "chat.agent.thinkingStyle": "collapsed",
    "chat.extensionUnification.enabled": false,
    "chat.math.enabled": false,
    "chat.mcp.access": "none",
    "chat.mcp.autostart": "never",
    "chat.notifyWindowOnResponseReceived": false,
    "chat.suspendThrottling": false,
    "chat.todoListTool.writeOnly": true,
    "chat.tools.edits.autoApprove": {
        "**/*": false
    },
    "chat.viewSessions.orientation": "stacked",
    "chat.viewTitle.enabled": false,
    "chat.viewWelcome.enabled": false
}
